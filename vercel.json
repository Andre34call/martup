{
  "buildCommand": "prisma generate && prisma db push --accept-data-loss && next build",
  "installCommand": "bun install",
  "framework": "nextjs",
  "functions": {
    "src/app/api/upload/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/stream/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/cancel-expired",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/auto-complete",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/auto-complete-stuck",
      "schedule": "0 9 * * *"
    }
  ]
}
