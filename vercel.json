{
  "buildCommand": "prisma generate && next build",
  "installCommand": "bun install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/cancel-expired",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/auto-complete",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/auto-complete-stuck",
      "schedule": "0 9 * * *"
    }
  ]
}
